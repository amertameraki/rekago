// ============================================================
// MODAL — TRY LIVE
// ============================================================
function openModal() {
  document.getElementById('modalOverlay').classList.add('open');
  document.getElementById('modalEmail').focus();
  document.getElementById('modalError').textContent = '';
}
function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
}

async function submitLogin() {
  const email = document.getElementById('modalEmail').value.trim();
  const errEl  = document.getElementById('modalError');
  errEl.textContent = '';

  if (!email || !email.includes('@')) {
    errEl.textContent = 'Enter a valid email address.';
    return;
  }

  // Demo mode — no config.js URL yet
  if (typeof REKAGO_CONFIG === 'undefined' || !REKAGO_CONFIG.gsUrl || REKAGO_CONFIG.gsUrl.includes('YOUR_APPS')) {
    errEl.textContent = 'Backend not configured yet. Running in demo mode.';
    return;
  }

  const btn = document.getElementById('btnLogin');
  btn.textContent = 'Connecting...';
  btn.disabled = true;

  try {
    const res  = await fetch(REKAGO_CONFIG.gsUrl, {
      method: 'POST',
      body: JSON.stringify({ action: 'login', email }),
    });
    const data = await res.json();

    if (data.ok) {
      state.mode  = 'live';
      state.email = email;
      closeModal();
      setLiveMode();
      await loadFromSheets();
      showToast('Connected — live data loaded.');
    } else {
      errEl.textContent = data.error || 'Access denied.';
    }
  } catch (e) {
    errEl.textContent = 'Connection failed. Check your config.js URL.';
  } finally {
    btn.textContent = COPY[state.lang]['modal.connect'] || 'Connect';
    btn.disabled    = false;
  }
}

function setLiveMode() {
  document.getElementById('modeBadge').style.display    = 'none';
  document.getElementById('btnTryLive').style.display   = 'none';
  document.getElementById('liveIndicator').style.display = 'flex';
  document.getElementById('demoGate').style.display      = 'none';
  document.getElementById('lastSynced').textContent =
    'Last updated: ' + new Date().toLocaleTimeString() + ' · Live mode';
}

// Demo unlock (edit gate — friction only, not security)
function unlockEdit() {
  const email = document.getElementById('gateEmail').value.trim();
  if (!email || !email.includes('@')) return;
  document.getElementById('demoGate').style.display = 'none';
  showToast('Edit mode unlocked (demo session).');
}

// ============================================================
// DATA — LOAD FROM SHEETS
// ============================================================
async function post(action, extra) {
  const res = await fetch(REKAGO_CONFIG.gsUrl, {
    method: 'POST',
    body: JSON.stringify({ action, email: state.email, ...extra }),
  });
  return res.json();
}

async function loadFromSheets() {
  const [skus, items, si, so, orders] = await Promise.all([
    fetch(REKAGO_CONFIG.gsUrl + '?action=getProducts').then(r => r.json()),
    fetch(REKAGO_CONFIG.gsUrl + '?action=getItems').then(r => r.json()),
    post('getStockIn'),
    post('getStockOut'),
    post('getSalesOrders'),
  ]);

  if (skus.ok)    state.skus         = skus.data;
  if (items.ok)   state.items        = items.data;
  if (si.ok)      state.stockIn      = si.data;
  if (so.ok)      state.stockOut     = so.data;
  if (orders.ok)  state.salesOrders  = orders.data;

  renderAll();
}

function getData() {
  return state.mode === 'live' ? state : MOCK;
}

// ============================================================
// RENDER — ALL
// ============================================================
function renderAll() {
  renderDashboard();
  renderProductsTable();
  renderStockInTable();
  renderStockOutTable();
  renderOrdersTable();
  populateSkuDropdowns();
}

// ============================================================
// RENDER — DASHBOARD
// ============================================================
function renderDashboard() {
  const d = getData();
  const skus = state.mode === 'live' ? state.skus : MOCK.skus;
  const items = state.mode === 'live' ? state.items : MOCK.items;

  const lowCount = skus.filter(s => s['SKU Status'] === 'Low Stock').length;
  document.getElementById('metricSkus').textContent  = skus.length;
  document.getElementById('metricItems').textContent = items.length;
  document.getElementById('metricLow').textContent   = lowCount;
  document.getElementById('lowBadge').textContent    = lowCount + ' low';

  // SKU table
  const tbody = document.getElementById('skuTableBody');
  tbody.innerHTML = skus.map(s => {
    const pct = Math.min(100, Math.round((s['Current Stock'] / Math.max(s['Reorder Threshold'] * 5, 1)) * 100));
    const isLow = s['SKU Status'] === 'Low Stock';
    const isOut = s['SKU Status'] === 'Out of Stock';
    const pillClass = isOut ? 'out' : isLow ? 'low-stock' : 'in-stock';
    const pillText  = isOut ? 'Out of Stock' : isLow ? 'Low Stock' : 'In Stock';
    return `<tr>
      <td style="padding-left:18px"><span class="sku-id">${s['SKU ID']}</span></td>
      <td><span class="sku-name">${s['SKU Name']}</span></td>
      <td>
        <div class="stock-bar-wrap">
          <div class="stock-bar-bg"><div class="stock-bar-fill ${isLow?'warn':''}" style="width:${pct}%"></div></div>
          <span class="stock-num">${s['Current Stock']}</span>
        </div>
      </td>
      <td style="padding-right:18px"><span class="status-pill ${pillClass}">${pillText}</span></td>
    </tr>`;
  }).join('');

  initChart();
}

// ============================================================
// CHART
// ============================================================
function initChart() {
  const ctx = document.getElementById('revenueChart').getContext('2d');
  if (state.revenueChart) state.revenueChart.destroy();

  const d = MOCK.chart[state.chartPeriod];

  state.revenueChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: d.labels,
      datasets: [
        {
          type: 'bar',
          label: 'Revenue',
          data: d.revenue,
          backgroundColor: 'rgba(242,187,22,0.72)',
          borderRadius: 3,
          yAxisID: 'yLeft',
        },
        {
          type: 'line',
          label: 'Orders',
          data: d.orders,
          borderColor: '#403919',
          backgroundColor: 'transparent',
          pointBackgroundColor: '#403919',
          pointBorderColor: '#FDFAF3',
          pointBorderWidth: 1.5,
          pointRadius: 4,
          tension: 0.4,
          yAxisID: 'yRight',
        },
      ],
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#fff',
          titleColor: '#403919',
          bodyColor: '#BF9E3B',
          borderColor: 'rgba(191,158,59,0.3)',
          borderWidth: 1,
          callbacks: {
            label: ctx => ctx.datasetIndex === 0
              ? 'Revenue: Rp ' + ctx.raw + 'M'
              : 'Orders: ' + ctx.raw,
          },
        },
      },
      scales: {
        x: {
          grid: { color: 'rgba(191,158,59,0.07)' },
          ticks: { color: '#BF9E3B', font: { size: 11 } },
        },
        yLeft: {
          position: 'left',
          grid: { color: 'rgba(191,158,59,0.07)' },
          ticks: { color: '#BF9E3B', font: { size: 11 }, callback: v => v },
        },
        yRight: {
          position: 'right',
          grid: { drawOnChartArea: false },
          ticks: { color: '#403919', font: { size: 11 } },
        },
      },
    },
  });
}

function setPeriod(p) {
  state.chartPeriod = p;
  document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
  event.currentTarget.classList.add('active');
  initChart();
}

// ============================================================
// RENDER — PRODUCTS TABLE
// ============================================================
function renderProductsTable() {
  const skus = state.mode === 'live' ? state.skus : MOCK.skus;
  const q    = document.getElementById('productSearch').value.toLowerCase();
  const cat  = state.activeCatFilter;

  const filtered = skus.filter(s =>
    (!cat || s['Category'] === cat) &&
    (!q || s['SKU Name'].toLowerCase().includes(q) || s['SKU ID'].toLowerCase().includes(q))
  );

  document.getElementById('productsBody').innerHTML = filtered.map(s => {
    const channels = (s['Channels'] || '').split(',').map(c => {
      const ch = c.trim();
      const cls = ch === 'Tokopedia' ? 'ch-tokopedia' : ch === 'Shopee' ? 'ch-shopee' : ch === 'TikTok Shop' ? 'ch-tiktok' : 'ch-direct';
      return `<span class="channel-pill ${cls}">${ch}</span>`;
    }).join('');
    const isLow = s['SKU Status'] === 'Low Stock';
    const isOut = s['SKU Status'] === 'Out of Stock';
    const pillClass = isOut ? 'out' : isLow ? 'low-stock' : 'in-stock';
    return `<tr>
      <td><span class="mono">${s['SKU ID']}</span></td>
      <td>${s['SKU Name']}</td>
      <td>${s['Category']}</td>
      <td>${channels}</td>
      <td>Rp ${Number(s['Unit Price (IDR)']).toLocaleString('id-ID')}</td>
      <td>${s['Current Stock']}</td>
      <td><span class="status-pill ${pillClass}">${s['SKU Status']}</span></td>
    </tr>`;
  }).join('') || '<tr><td colspan="7" class="text-muted" style="text-align:center;padding:24px">No products found</td></tr>';
}

function filterCat(btn, cat) {
  state.activeCatFilter = cat;
  document.querySelectorAll('#page-products .cat-pill').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProductsTable();
}

