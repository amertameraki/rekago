<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rekago — Inventory, rekapped</title>
<script src="config.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ============================================================
   DESIGN TOKENS
   ============================================================ */
:root {
  --bg:       #FDFAF3;
  --nav:      #403919;
  --gold:     #F2BB16;
  --amber:    #BF9E3B;
  --warn:     #A6600A;
  --ok:       #5C8A1A;
  --danger:   #C0392B;
  --surface:  #FFFFFF;
  --border:   rgba(191,158,59,0.2);
  --text:     #403919;
  --muted:    rgba(64,57,25,0.5);

  --ch-tokopedia: #E05E1E;
  --ch-shopee:    #D0001B;
  --ch-tiktok:    #1DAB52;
  --ch-direct:    #1A6A9A;

  --radius:   8px;
  --shadow:   0 1px 4px rgba(64,57,25,0.08);
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; }
body {
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  background: var(--bg);
  color: var(--text);
  line-height: 1.5;
}
button { cursor: pointer; font-family: inherit; }
input, select, textarea { font-family: inherit; font-size: 13px; }
a { color: inherit; text-decoration: none; }

/* ============================================================
   LAYOUT
   ============================================================ */
#app { display: flex; flex-direction: column; min-height: 100vh; }

/* ============================================================
   NAV
   ============================================================ */
nav {
  background: var(--nav);
  display: flex;
  align-items: center;
  padding: 0 24px;
  height: 48px;
  gap: 32px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-brand {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
  min-width: 110px;
}
.nav-brand-name {
  font-family: 'DM Serif Display', serif;
  font-size: 18px;
  color: var(--gold);
  letter-spacing: -0.3px;
}
.nav-brand-sub {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: rgba(242,187,22,0.45);
}
.nav-tabs {
  display: flex;
  gap: 2px;
  flex: 1;
  justify-content: center;
}
.nav-tab {
  background: none;
  border: none;
  color: rgba(242,187,22,0.55);
  font-size: 13px;
  font-weight: 500;
  padding: 6px 14px;
  border-radius: 6px;
  transition: color 0.15s, background 0.15s;
}
.nav-tab:hover { color: var(--gold); background: rgba(242,187,22,0.07); }
.nav-tab.active { color: var(--nav); background: var(--gold); font-weight: 600; }

.nav-right {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 220px;
  justify-content: flex-end;
}
.lang-btn {
  background: none;
  border: none;
  color: rgba(242,187,22,0.5);
  font-size: 11px;
  font-weight: 600;
  padding: 3px 6px;
  border-radius: 4px;
  transition: color 0.15s;
}
.lang-btn:hover, .lang-btn.active { color: var(--gold); }
.demo-badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.8px;
  color: var(--warn);
  background: rgba(166,96,10,0.12);
  padding: 3px 8px;
  border-radius: 4px;
  text-transform: uppercase;
}
.btn-trylive {
  background: var(--gold);
  color: var(--nav);
  border: none;
  font-size: 12px;
  font-weight: 700;
  padding: 6px 14px;
  border-radius: 6px;
  transition: opacity 0.15s;
}
.btn-trylive:hover { opacity: 0.88; }
.live-indicator {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--ok);
  font-weight: 600;
}
.live-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--ok);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ============================================================
   MAIN CONTENT
   ============================================================ */
main { flex: 1; padding: 24px; max-width: 1280px; margin: 0 auto; width: 100%; }

.page { display: none; }
.page.active { display: block; }

/* ============================================================
   PAGE HEADER
   ============================================================ */
.page-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20px;
}
.page-title {
  font-family: 'DM Serif Display', serif;
  font-size: 24px;
  color: var(--text);
  letter-spacing: -0.3px;
}
.page-meta {
  font-size: 11px;
  color: var(--muted);
  margin-top: 2px;
}

/* ============================================================
   DEMO GATE BANNER
   ============================================================ */
.demo-gate {
  background: rgba(242,187,22,0.07);
  border: 1px solid rgba(242,187,22,0.25);
  border-radius: var(--radius);
  padding: 12px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  gap: 16px;
}
.demo-gate-text strong { font-weight: 600; font-size: 13px; color: var(--text); }
.demo-gate-text p { font-size: 12px; color: var(--muted); margin-top: 1px; }
.demo-gate-right { display: flex; align-items: center; gap: 8px; }
.demo-gate input {
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 6px 12px;
  font-size: 12px;
  background: var(--surface);
  color: var(--text);
  width: 200px;
  outline: none;
  transition: border 0.15s;
}
.demo-gate input:focus { border-color: var(--amber); }
.btn-unlock {
  background: var(--gold);
  color: var(--nav);
  border: none;
  font-size: 12px;
  font-weight: 700;
  padding: 6px 16px;
  border-radius: 6px;
}

/* ============================================================
   METRIC CARDS
   ============================================================ */
.metrics-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 20px;
}
.metric-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 20px;
  box-shadow: var(--shadow);
}
.metric-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 6px;
}
.metric-value {
  font-size: 28px;
  font-weight: 600;
  color: var(--text);
  line-height: 1;
  margin-bottom: 4px;
}
.metric-sub { font-size: 11px; color: var(--muted); }
.metric-card.warn { border-left: 3px solid var(--warn); }
.metric-card.ok   { border-left: 3px solid var(--ok); }

/* ============================================================
   DASHBOARD GRID
   ============================================================ */
.dash-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* ============================================================
   CARDS
   ============================================================ */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px 10px;
  border-bottom: 1px solid var(--border);
}
.card-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--amber);
}
.card-body { padding: 16px 18px; }

/* ============================================================
   SKU OVERVIEW TABLE
   ============================================================ */
.sku-table { width: 100%; border-collapse: collapse; }
.sku-table th {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--amber);
  padding: 0 0 8px;
  text-align: left;
  border-bottom: 1px solid var(--border);
}
.sku-table th:not(:first-child) { padding-left: 12px; }
.sku-table td {
  padding: 10px 0;
  border-bottom: 1px solid rgba(191,158,59,0.08);
  vertical-align: middle;
}
.sku-table td:not(:first-child) { padding-left: 12px; }
.sku-table tr:last-child td { border-bottom: none; }
.sku-id {
  font-family: 'Courier New', monospace;
  font-size: 11px;
  color: var(--amber);
  font-weight: 600;
}
.sku-name { font-size: 13px; font-weight: 500; }

/* Stock bar */
.stock-bar-wrap { display: flex; align-items: center; gap: 8px; }
.stock-bar-bg {
  width: 80px; height: 4px;
  background: rgba(191,158,59,0.15);
  border-radius: 2px;
  overflow: hidden;
}
.stock-bar-fill {
  height: 100%;
  border-radius: 2px;
  background: var(--gold);
  transition: width 0.4s ease;
}
.stock-bar-fill.warn { background: var(--warn); }
.stock-num { font-size: 12px; font-weight: 500; color: var(--text); min-width: 24px; }

/* Status pill */
.status-pill {
  display: inline-flex;
  align-items: center;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 4px;
  white-space: nowrap;
}
.status-pill.in-stock  { background: rgba(92,138,26,0.1);  color: var(--ok);   }
.status-pill.low-stock { background: rgba(166,96,10,0.1);  color: var(--warn); }
.status-pill.out       { background: rgba(192,57,43,0.1);  color: var(--danger); }

/* Badge */
.badge-warn {
  font-size: 10px;
  font-weight: 700;
  background: rgba(166,96,10,0.1);
  color: var(--warn);
  padding: 2px 8px;
  border-radius: 4px;
}

/* ============================================================
   REVENUE & ORDERS CHART
   ============================================================ */
.period-toggle { display: flex; gap: 4px; }
.period-btn {
  background: none;
  border: 1px solid var(--border);
  color: var(--muted);
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 5px;
  transition: all 0.15s;
}
.period-btn.active {
  background: var(--gold);
  border-color: var(--gold);
  color: var(--nav);
}
.chart-legend {
  display: flex;
  gap: 16px;
  padding: 8px 18px 0;
}
.legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--muted); }
.legend-swatch {
  width: 12px; height: 10px;
  border-radius: 2px;
  background: rgba(242,187,22,0.72);
}
.legend-line {
  width: 18px; height: 2px;
  background: var(--nav);
  position: relative;
}
.legend-line::after {
  content: '';
  position: absolute;
  right: -1px; top: -3px;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--nav);
  border: 1.5px solid var(--bg);
}
.chart-wrap { padding: 8px 16px 16px; }

/* ============================================================
   PRODUCTS PAGE
   ============================================================ */
.filter-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.search-input {
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 7px 12px;
  background: var(--surface);
  color: var(--text);
  outline: none;
  width: 220px;
  transition: border 0.15s;
}
.search-input:focus { border-color: var(--amber); }
.cat-pill {
  background: none;
  border: 1px solid var(--border);
  color: var(--muted);
  font-size: 11px;
  font-weight: 600;
  padding: 5px 12px;
  border-radius: 20px;
  transition: all 0.15s;
}
.cat-pill:hover, .cat-pill.active {
  border-color: var(--gold);
  color: var(--text);
  background: rgba(242,187,22,0.08);
}

.data-table { width: 100%; border-collapse: collapse; }
.data-table th {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--amber);
  padding: 10px 14px;
  text-align: left;
  background: rgba(191,158,59,0.05);
  border-bottom: 1px solid var(--border);
}
.data-table td {
  padding: 10px 14px;
  border-bottom: 1px solid rgba(191,158,59,0.08);
  vertical-align: middle;
}
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: rgba(242,187,22,0.03); }

/* Channel pills */
.channel-pill {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 3px;
  margin: 1px 2px 1px 0;
  color: #fff;
}
.ch-tokopedia { background: var(--ch-tokopedia); }
.ch-shopee    { background: var(--ch-shopee); }
.ch-tiktok    { background: var(--ch-tiktok); }
.ch-direct    { background: var(--ch-direct); }

/* ============================================================
   FORMS
   ============================================================ */
.form-section {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 24px;
  margin-bottom: 20px;
  box-shadow: var(--shadow);
}
.form-section-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}
.form-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}
.form-grid-2 { grid-template-columns: repeat(2, 1fr); }
.form-grid-4 { grid-template-columns: repeat(4, 1fr); }
.form-field { display: flex; flex-direction: column; gap: 5px; }
.form-field.full { grid-column: 1 / -1; }
.form-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--amber);
}
.form-input, .form-select, .form-textarea {
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 8px 12px;
  background: var(--bg);
  color: var(--text);
  outline: none;
  transition: border 0.15s;
  width: 100%;
}
.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color: var(--amber);
  background: var(--surface);
}
.form-textarea { resize: vertical; min-height: 72px; }
.checkbox-group { display: flex; gap: 12px; flex-wrap: wrap; padding-top: 2px; }
.checkbox-item { display: flex; align-items: center; gap: 6px; font-size: 12px; cursor: pointer; }
.checkbox-item input { cursor: pointer; accent-color: var(--gold); }
.form-actions { margin-top: 16px; display: flex; gap: 10px; }

.btn-primary {
  background: var(--gold);
  color: var(--nav);
  border: none;
  font-size: 13px;
  font-weight: 700;
  padding: 9px 20px;
  border-radius: 6px;
  transition: opacity 0.15s;
}
.btn-primary:hover { opacity: 0.88; }
.btn-secondary {
  background: none;
  color: var(--muted);
  border: 1px solid var(--border);
  font-size: 13px;
  font-weight: 500;
  padding: 9px 18px;
  border-radius: 6px;
  transition: all 0.15s;
}
.btn-secondary:hover { border-color: var(--amber); color: var(--text); }

/* ============================================================
   MODAL — TRY LIVE
   ============================================================ */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(64,57,25,0.45);
  z-index: 200;
  align-items: center;
  justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--surface);
  border-radius: 12px;
  padding: 32px;
  width: 400px;
  box-shadow: 0 8px 40px rgba(64,57,25,0.18);
}
.modal-brand {
  font-family: 'DM Serif Display', serif;
  font-size: 20px;
  color: var(--gold);
  margin-bottom: 6px;
}
.modal-title { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
.modal-sub { font-size: 12px; color: var(--muted); margin-bottom: 24px; line-height: 1.5; }
.modal-field { margin-bottom: 16px; }
.modal-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 6px;
  display: block;
}
.modal-input {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 13px;
  background: var(--bg);
  color: var(--text);
  outline: none;
  transition: border 0.15s;
}
.modal-input:focus { border-color: var(--amber); }
.modal-error {
  font-size: 12px;
  color: var(--danger);
  margin-top: 8px;
  min-height: 16px;
}
.modal-actions { display: flex; gap: 10px; margin-top: 20px; }
.btn-modal-primary {
  flex: 1;
  background: var(--gold);
  color: var(--nav);
  border: none;
  font-size: 13px;
  font-weight: 700;
  padding: 11px;
  border-radius: 8px;
  transition: opacity 0.15s;
}
.btn-modal-primary:hover { opacity: 0.88; }
.btn-modal-secondary {
  background: none;
  border: 1px solid var(--border);
  color: var(--muted);
  font-size: 13px;
  padding: 11px 18px;
  border-radius: 8px;
}
.modal-note {
  font-size: 11px;
  color: var(--muted);
  margin-top: 16px;
  line-height: 1.5;
  text-align: center;
}

/* ============================================================
   EMPTY STATE
   ============================================================ */
.empty-state {
  text-align: center;
  padding: 40px 20px;
  color: var(--muted);
}
.empty-state p { font-size: 13px; margin-top: 4px; }

/* ============================================================
   TOAST
   ============================================================ */
.toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  background: var(--nav);
  color: var(--gold);
  font-size: 13px;
  font-weight: 500;
  padding: 12px 20px;
  border-radius: 8px;
  box-shadow: 0 4px 20px rgba(64,57,25,0.2);
  z-index: 300;
  transform: translateY(80px);
  opacity: 0;
  transition: all 0.25s ease;
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.error { background: var(--danger); color: #fff; }

/* ============================================================
   UTILITY
   ============================================================ */
.text-muted  { color: var(--muted); }
.text-ok     { color: var(--ok); }
.text-warn   { color: var(--warn); }
.text-danger { color: var(--danger); }
.mono        { font-family: 'Courier New', monospace; font-size: 11px; color: var(--amber); }
</style>
</head>
<body>
<div id="app">

<!-- ============================================================
     NAV
     ============================================================ -->
<nav>
  <div class="nav-brand">
    <span class="nav-brand-name">Rekago</span>
    <span class="nav-brand-sub">재고 · Inventory</span>
  </div>

  <div class="nav-tabs">
    <button class="nav-tab active" onclick="showPage('dashboard')">Dashboard</button>
    <button class="nav-tab" onclick="showPage('products')">Products</button>
    <button class="nav-tab" onclick="showPage('stockin')">Stock In</button>
    <button class="nav-tab" onclick="showPage('stockout')">Stock Out</button>
    <button class="nav-tab" onclick="showPage('salesorders')">Sales Orders</button>
  </div>

  <div class="nav-right">
    <button class="lang-btn active" onclick="setLang('en')">EN</button>
    <button class="lang-btn" onclick="setLang('id')">ID</button>
    <button class="lang-btn" onclick="setLang('ko')">한국어</button>
    <span class="demo-badge" id="modeBadge">DEMO</span>
    <button class="btn-trylive" id="btnTryLive" onclick="openModal()">Try Live</button>
    <div class="live-indicator" id="liveIndicator" style="display:none">
      <span class="live-dot"></span>
      <span>Live</span>
    </div>
  </div>
</nav>

<!-- ============================================================
     MAIN
     ============================================================ -->
<main>

  <!-- DASHBOARD -->
  <div class="page active" id="page-dashboard">
    <div class="page-header">
      <div>
        <div class="page-title" data-key="nav.dashboard">Dashboard</div>
        <div class="page-meta" id="lastSynced">Last updated: Today, demo mode</div>
      </div>
    </div>

    <!-- Demo gate -->
    <div class="demo-gate" id="demoGate">
      <div class="demo-gate-text">
        <strong data-key="gate.title">Want to edit data?</strong>
        <p data-key="gate.sub">Enter your email to unlock editing in this demo session</p>
      </div>
      <div class="demo-gate-right">
        <input type="email" id="gateEmail" placeholder="your@email.com">
        <button class="btn-unlock" onclick="unlockEdit()" data-key="btn.unlock">Unlock</button>
      </div>
    </div>

    <!-- Metrics -->
    <div class="metrics-row">
      <div class="metric-card">
        <div class="metric-label" data-key="m.totalskus">Total SKUs</div>
        <div class="metric-value" id="metricSkus">3</div>
        <div class="metric-sub" data-key="m.skusactive">SKUs active</div>
      </div>
      <div class="metric-card">
        <div class="metric-label" data-key="m.totalitems">Total Items</div>
        <div class="metric-value" id="metricItems">5</div>
        <div class="metric-sub" data-key="m.variantstracked">variants tracked</div>
      </div>
      <div class="metric-card warn">
        <div class="metric-label" data-key="m.lowstock">Low Stock</div>
        <div class="metric-value" id="metricLow">1</div>
        <div class="metric-sub" data-key="m.needrestock">SKU needs restock</div>
      </div>
      <div class="metric-card ok">
        <div class="metric-label" data-key="m.movedweek">Sold This Week</div>
        <div class="metric-value" id="metricSold">22</div>
        <div class="metric-sub" data-key="m.unitsout">units out</div>
      </div>
    </div>

