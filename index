// ============================================================
// RENDER — ORDERS TABLE
// ============================================================
function renderOrdersTable() {
  const orders = state.mode === 'live' ? state.salesOrders : MOCK.salesOrders;
  const q      = document.getElementById('orderSearch').value.toLowerCase();
  const ch     = state.activeChannelFilter;

  const filtered = orders.filter(o =>
    (!ch || o['Channel'] === ch) &&
    (!q || o['SO Number'].toLowerCase().includes(q) || (o['Customer Ref']||'').toLowerCase().includes(q))
  );

  document.getElementById('ordersBody').innerHTML = filtered.map(o => {
    const chCls = o['Channel'] === 'Tokopedia' ? 'ch-tokopedia' : o['Channel'] === 'Shopee' ? 'ch-shopee' : o['Channel'] === 'TikTok Shop' ? 'ch-tiktok' : 'ch-direct';
    const stCls = o['Status'] === 'Fulfilled' ? 'in-stock' : o['Status'] === 'Cancelled' ? 'out' : 'low-stock';
    return `<tr>
      <td class="mono">${o['SO Number']}</td>
      <td>${o['Date']}</td>
      <td><span class="channel-pill ${chCls}">${o['Channel']}</span></td>
      <td>${o['Customer Ref'] || ''}</td>
      <td>${o['Total Qty']}</td>
      <td>Rp ${Number(o['Total Revenue (IDR)']).toLocaleString('id-ID')}</td>
      <td><span class="status-pill ${stCls}">${o['Status']}</span></td>
    </tr>`;
  }).join('') || '<tr><td colspan="7" class="text-muted" style="text-align:center;padding:24px">No orders found</td></tr>';
}

function filterChannel(btn, ch) {
  state.activeChannelFilter = ch;
  document.querySelectorAll('#page-salesorders .cat-pill').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderOrdersTable();
}

// ============================================================
// FORM DROPDOWNS
// ============================================================
function populateSkuDropdowns() {
  const skus = state.mode === 'live' ? state.skus : MOCK.skus;
  ['siSkuId','soSkuId'].forEach(id => {
    const sel = document.getElementById(id);
    sel.innerHTML = skus.map(s => `<option value="${s['SKU ID']}">${s['SKU ID']} — ${s['SKU Name']}</option>`).join('');
  });
  populateItems('siSkuId','siItemId');
  populateItems('soSkuId','soItemId');
}

function populateItems(skuSelId, itemSelId) {
  const skuId = document.getElementById(skuSelId).value;
  const items = state.mode === 'live' ? state.items : MOCK.items;
  const filtered = items.filter(i => i['SKU ID'] === skuId);
  document.getElementById(itemSelId).innerHTML =
    filtered.map(i => `<option value="${i['Item ID']}">${i['Item ID']} — ${i['Item Name']}</option>`).join('');
}

// ============================================================
// FORM SUBMISSIONS
// ============================================================
async function submitAddProduct() {
  if (state.mode !== 'live') { showToast('Connect to live mode to add products.', true); return; }
  const channels = [...document.querySelectorAll('#addProductForm input[type=checkbox]:checked')].map(c => c.value);
  const payload  = {
    skuId: document.getElementById('fpSkuId').value.trim(),
    skuName: document.getElementById('fpSkuName').value.trim(),
    category: document.getElementById('fpCategory').value,
    channels,
    unitPrice: document.getElementById('fpUnitPrice').value,
    costPrice: document.getElementById('fpCostPrice').value,
    reorderThreshold: document.getElementById('fpReorder').value,
    notes: document.getElementById('fpNotes').value,
  };
  if (!payload.skuId || !payload.skuName) { showToast('SKU ID and name are required.', true); return; }
  const res = await post('addProduct', payload);
  if (res.ok) { showToast('Product added.'); await loadFromSheets(); }
  else showToast(res.error || 'Error adding product.', true);
}

async function submitStockIn() {
  if (state.mode !== 'live') { showToast('Connect to live mode to record stock.', true); return; }
  const payload = {
    date: document.getElementById('siDate').value,
    refId: document.getElementById('siRefId').value,
    skuId: document.getElementById('siSkuId').value,
    itemId: document.getElementById('siItemId').value,
    supplier: document.getElementById('siSupplier').value,
    qty: document.getElementById('siQty').value,
    unitCost: document.getElementById('siUnitCost').value,
    type: document.getElementById('siType').value,
    notes: document.getElementById('siNotes').value,
  };
  const res = await post('addStockIn', payload);
  if (res.ok) { showToast('Stock In recorded.'); await loadFromSheets(); }
  else showToast(res.error || 'Error.', true);
}

